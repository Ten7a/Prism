# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/prism"

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
# GitHub OAuth
# https://www.better-auth.com/docs/authentication/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Email — Resend is preferred. SMTP_URL is the self-host fallback (e.g. smtp://user:pass@host:587).
RESEND_API_KEY=""
SMTP_URL=""
EMAIL_FROM="Prism <noreply@prism.test>"

# OpenRouter — image model catalogue + generation.
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Storage — Cloudflare R2 (or any S3-compatible store via aws4fetch).
# STORAGE_DRIVER: "r2" picks the Workers R2 binding when available; "s3" forces the HTTP driver.
STORAGE_DRIVER="s3"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Optional CDN base for serving public objects (e.g. https://cdn.prism.example).
R2_PUBLIC_BASE_URL=""

# Tokens — free daily allowance granted lazily on first authenticated request of a UTC day.
DAILY_ALLOWANCE_TOKENS="10"

# Stripe — checkout, customer portal, and webhook signing.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLIC_KEY=""

# Rate limits — token-bucket spec like "60/m", "200/h". A Cloudflare KV binding
# named RATE_LIMIT (declared in wrangler) is used in production; the in-memory
# fallback is used for local dev / Node builds / tests.
RATE_LIMIT_ANON="60/m"
RATE_LIMIT_USER="600/h"
RATE_LIMIT_GENERATIONS="30/h"
RATE_LIMIT_UPLOADS="30/h"

# Moderation — OpenRouter model id; leave empty in dev to disable.
MODERATION_MODEL="openai/omni-moderation-latest"

# AdSense — consent-gated; leave empty in dev to disable.
# data-ad-client (ca-pub-…) and per-slot data-ad-slot IDs from the AdSense console.
PUBLIC_ADSENSE_CLIENT_ID=""
PUBLIC_ADSENSE_SLOT_LIBRARY_TOP=""
PUBLIC_ADSENSE_SLOT_LANDING_FOOTER=""
