# --- Core ---
ORIGIN="http://localhost:3000"
PUBLIC_APP_NAME="Prism"
DATABASE_URL="postgres://prism:prism@localhost:5432/prism"
# 32+ random chars; generate with `openssl rand -hex 32`. bin/setup.sh fills this if blank.
BETTER_AUTH_SECRET=""

# --- Auth providers (optional) ---
# https://www.better-auth.com/docs/authentication/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- OpenRouter — image model catalogue + generation ---
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# --- Storage — Cloudflare R2 (or any S3-compatible store via aws4fetch) ---
# "r2" picks the Workers R2 binding when available; "s3" forces the HTTP driver.
STORAGE_DRIVER="s3"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="prism"
# https://<account>.r2.cloudflarestorage.com (or any S3 endpoint).
R2_ENDPOINT=""
# Optional CDN base for serving public objects (e.g. https://cdn.prism.example).
R2_PUBLIC_BASE_URL=""

# --- Email — Resend preferred; SMTP_URL is the self-host fallback ---
RESEND_API_KEY=""
SMTP_URL=""                  # smtp://user:pass@host:587
EMAIL_FROM="Prism <noreply@prism.example>"

# --- Stripe — checkout, customer portal, and webhook signing ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLIC_KEY=""

# --- Tokens — free daily allowance granted lazily on first request of a UTC day ---
DAILY_ALLOWANCE_TOKENS="10"

# --- Ads (optional, consent-gated) ---
PUBLIC_ADSENSE_CLIENT_ID=""
PUBLIC_ADSENSE_SLOT_LIBRARY_TOP=""
PUBLIC_ADSENSE_SLOT_LANDING_FOOTER=""

# --- Rate limit / abuse ---
# Token-bucket spec like "60/m", "200/h". KV binding RATE_LIMIT used on Workers;
# in-memory fallback on Node/dev/tests. MODERATION_MODEL: leave empty to disable.
RATE_LIMIT_ANON="60/m"
RATE_LIMIT_USER="600/h"
RATE_LIMIT_GENERATIONS="30/h"
RATE_LIMIT_UPLOADS="30/h"
MODERATION_MODEL="openai/omni-moderation-latest"

# --- Observability ---
# Structured logger level; optional Sentry sink (POST envelopes directly to DSN);
# bearer-gated /api/metrics; deployed git commit surfaced by /api/healthz.
LOG_LEVEL="info"
SENTRY_DSN=""
METRICS_TOKEN=""
GIT_SHA=""
